{
  "$defs": {
    "CredentialsModel": {
      "description": "Model for storing credentials used in password authentication attempts.",
      "properties": {
        "user": {
          "description": "Username",
          "title": "User",
          "type": "string"
        },
        "password": {
          "description": "Password",
          "title": "Password",
          "type": "string"
        }
      },
      "required": [
        "user",
        "password"
      ],
      "title": "CredentialsModel",
      "type": "object"
    },
    "PasswordScanResultModel": {
      "description": "Model for storing results of password authentication attempts.",
      "properties": {
        "ip": {
          "description": "Target IP address",
          "format": "ipvanyaddress",
          "title": "Ip",
          "type": "string"
        },
        "port": {
          "description": "Target port number",
          "title": "Port",
          "type": "integer"
        },
        "service": {
          "$ref": "#/$defs/ServiceEnum",
          "description": "Service type being tested"
        },
        "login_attempt": {
          "$ref": "#/$defs/StatusEnum",
          "description": "Status of login attempt"
        },
        "credentials": {
          "anyOf": [
            {
              "$ref": "#/$defs/CredentialsModel"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Credentials if login attempt is 'successful'"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Error message if any",
          "title": "Error"
        },
        "product_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name of product using port",
          "title": "Product Name"
        },
        "product_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Version of product using port",
          "title": "Product Version"
        },
        "device_correlation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Anonymous ID for correlating devices across scans",
          "title": "Device Correlation Id"
        }
      },
      "required": [
        "ip",
        "port",
        "service",
        "login_attempt"
      ],
      "title": "PasswordScanResultModel",
      "type": "object"
    },
    "ServiceEnum": {
      "description": "Service model, a list of services that we test passwords against.",
      "enum": [
        "ssh",
        "ftp",
        "telnet",
        "smb"
      ],
      "title": "ServiceEnum",
      "type": "string"
    },
    "StatusEnum": {
      "description": "Status model, a list of status's for password authentication attempts.",
      "enum": [
        "successful",
        "failed",
        "ratelimit",
        "unknown"
      ],
      "title": "StatusEnum",
      "type": "string"
    }
  },
  "description": "Model for storing password scan results.",
  "properties": {
    "id": {
      "description": "Unique identifier for the report.",
      "title": "Id",
      "type": "string"
    },
    "device_id": {
      "default": "test-device",
      "description": "Unique identifier for the module. (hash of MAC address)",
      "title": "Device Id",
      "type": "string"
    },
    "version": {
      "default": "0.1.0",
      "description": "Version number of the CLI.",
      "format": "semver",
      "title": "Version",
      "type": "string"
    },
    "module": {
      "default": "unspecified",
      "description": "Name of the module that ran.",
      "title": "Module",
      "type": "string"
    },
    "module_version": {
      "default": "0.1.0",
      "description": "Version number of the module.",
      "format": "semver",
      "title": "Module Version",
      "type": "string"
    },
    "timestamp": {
      "description": "Timestamp when the module was run.",
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    },
    "is_demo": {
      "default": false,
      "description": "True if results are from demo mode.",
      "title": "Is Demo",
      "type": "boolean"
    },
    "results": {
      "description": "List of password scan results",
      "items": {
        "$ref": "#/$defs/PasswordScanResultModel"
      },
      "title": "Results",
      "type": "array"
    },
    "summary": {
      "additionalProperties": true,
      "description": "Summary of scan results",
      "title": "Summary",
      "type": "object"
    },
    "hosts": {
      "description": "List of hosts (for backward compatibility)",
      "items": {},
      "title": "Hosts",
      "type": "array"
    }
  },
  "required": [
    "results"
  ],
  "title": "EdgeWalker Password Scan Telemetry Schema",
  "type": "object"
}
